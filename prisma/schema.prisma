// Prisma + PostgreSQL: пользователи, организации, RBAC, токены писем, аудит auth
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Роль участника организации (владелец хранится отдельно в Organization.ownerId)
enum OrgRole {
  ADMIN
  STAFF
}

/// Назначение одноразового токена из письма
enum AuthTokenPurpose {
  VERIFY_EMAIL
  PASSWORD_RESET
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  name                String?
  /// Заполняется после перехода по ссылке из письма подтверждения
  emailVerifiedAt     DateTime?
  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  /// Увеличивается при смене пароля — инвалидация всех JWT-сессий
  sessionVersion      Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization          Organization?
  organizationMembers OrganizationMember[]
  authTokens          AuthEmailToken[]
  auditLogs           AuditLog[]
}

/// Одноразовые токены подтверждения почты и сброса пароля (в БД только hash)
model AuthEmailToken {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String           @unique
  purpose   AuthTokenPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, purpose])
}

/// Участник организации (не владелец): админ или сотрудник
model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           OrgRole      @default(STAFF)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
}

/// События безопасности для разборов инцидентов
model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String?
  action         String
  meta           Json?
  ip             String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model Organization {
  id     String @id @default(cuid())
  slug   String @unique
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  businessName String
  description  String @default("")
  phone        String @default("")
  emailContact String @default("")

  timezone        String @default("Europe/Moscow")
  accentColor     String @default("#0d9488")
  pageBackgroundColor    String  @default("#f5f5f4")
  pageBackgroundImageUrl String?
  logoUrl         String?
  minAdvanceHours Int    @default(2)
  slotStepMinutes Int    @default(30)

  suspended            Boolean @default(false)
  publicBookingEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       OrganizationMember[]
  services      Service[]
  weeklySlots   WeeklySlot[]
  adHocDaySlots AdHocDaySlot[]
  bookings      Booking[]
  slotLocks     BookingSlotLock[]
  blockedDates  BlockedDate[]
}

model Service {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  durationMinutes Int
  priceCents      Int?
  active          Boolean      @default(true)
  sortOrder       Int          @default(0)

  bookings Booking[]
}

model WeeklySlot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  startMinutes   Int
  endMinutes     Int
}

model AdHocDaySlot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dateStr        String
  startMinutes   Int
  endMinutes     Int

  @@index([organizationId, dateStr])
}

model BlockedDate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dateStr        String
  reason         String?

  @@unique([organizationId, dateStr])
}

model Booking {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  clientName  String
  clientPhone String
  clientEmail String?
  notes       String?

  startsAt       DateTime
  endsAt         DateTime
  idempotencyKey String?
  status         String  @default("CONFIRMED")

  createdAt DateTime @default(now())

  slotLocks BookingSlotLock[]

  @@unique([organizationId, idempotencyKey])
}

model BookingSlotLock {
  id             String       @id @default(cuid())
  organizationId String
  bookingId      String
  slotStart      DateTime
  booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slotStart])
  @@index([bookingId])
}
