// Prisma + PostgreSQL: владелец (User), организация, услуги, расписание, записи
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  // Верификация почты сейчас отключена: при регистрации сразу ставим дату, чтобы вход работал без писем
  emailVerifiedAt DateTime?
  failedLoginAttempts Int      @default(0)
  lockoutUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  organization Organization?
}

model Organization {
  id     String @id @default(cuid())
  slug   String @unique
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  businessName String
  description  String @default("")
  phone        String @default("")
  emailContact String @default("")

  timezone        String @default("Europe/Moscow")
  accentColor     String @default("#0d9488")
  pageBackgroundColor    String  @default("#f5f5f4")
  pageBackgroundImageUrl String?
  logoUrl         String?
  minAdvanceHours Int    @default(2)
  slotStepMinutes Int    @default(30)

  suspended            Boolean @default(false)
  publicBookingEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services      Service[]
  weeklySlots   WeeklySlot[]
  adHocDaySlots AdHocDaySlot[]
  bookings      Booking[]
  slotLocks     BookingSlotLock[]
  blockedDates  BlockedDate[]
}

model Service {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  durationMinutes Int
  priceCents      Int?
  active          Boolean      @default(true)
  sortOrder       Int          @default(0)

  bookings Booking[]
}

model WeeklySlot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  startMinutes   Int
  endMinutes     Int
}

model AdHocDaySlot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dateStr        String
  startMinutes   Int
  endMinutes     Int

  @@index([organizationId, dateStr])
}

model BlockedDate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dateStr        String
  reason         String?

  @@unique([organizationId, dateStr])
}

model Booking {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  clientName  String
  clientPhone String
  clientEmail String?
  notes       String?

  startsAt       DateTime
  endsAt         DateTime
  idempotencyKey String?
  status         String  @default("CONFIRMED")

  createdAt DateTime @default(now())

  slotLocks BookingSlotLock[]

  @@unique([organizationId, idempotencyKey])
}

model BookingSlotLock {
  id             String       @id @default(cuid())
  organizationId String
  bookingId      String
  slotStart      DateTime
  booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slotStart])
  @@index([bookingId])
}
