// Схема Prisma: пользователь, организация (витрина записи), услуги, недельное расписание, блокировки дат, записи клиентов
generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Временный откат на SQLite, чтобы сайт снова работал локально без внешней БД.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Владелец: вход в админ-панель по email/паролю
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  // Дата подтверждения email нужна, чтобы закрыть вход до верификации почты
  emailVerifiedAt DateTime?
  // Счетчик неудачных логинов нужен для lockout после серии ошибочных попыток
  failedLoginAttempts Int      @default(0)
  // Временная блокировка входа до указанного момента
  lockoutUntil DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization?
  // Токены подтверждения email хранятся отдельно, чтобы можно было безопасно перевыпускать ссылки
  emailVerificationTokens EmailVerificationToken[]
  // Токены сброса пароля хранятся отдельно с TTL и одноразовым использованием
  passwordResetTokens PasswordResetToken[]
}

// Организация: один владелец, публичный slug для ссылки /book/[slug]
model Organization {
  id     String @id @default(cuid())
  slug   String @unique
  // Связь 1:1 с владельцем
  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  businessName String
  description  String @default("")
  phone        String @default("")
  emailContact String @default("")

  timezone        String @default("Europe/Moscow")
  accentColor     String @default("#0d9488")
  // Фон витрины /book: заливка + опциональное фото (за контентом, z-index ниже)
  pageBackgroundColor    String  @default("#f5f5f4")
  pageBackgroundImageUrl String?
  logoUrl         String?
  minAdvanceHours Int    @default(2)
  slotStepMinutes Int    @default(30)

  // Доступ: suspended — полная блокировка (задаёте вы вручную в БД/Studio); publicBookingEnabled — публичная витрина (может снять владелец в настройках)
  suspended            Boolean @default(false)
  publicBookingEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services     Service[]
  weeklySlots  WeeklySlot[]
  adHocDaySlots AdHocDaySlot[]
  bookings     Booking[]
  // Отдельные строки блокировок шагов занятости для защиты от конкурентных записей
  slotLocks    BookingSlotLock[]
  blockedDates BlockedDate[]
}

// Услуга: длительность влияет на шаг занятости слотов
model Service {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  durationMinutes Int
  priceCents      Int?
  active          Boolean      @default(true)
  sortOrder       Int          @default(0)

  bookings Booking[]
}

// Окно работы в конкретный день недели: dayOfWeek как в JS Date.getDay() (0 — вс, 1 — пн, … 6 — сб)
model WeeklySlot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  startMinutes   Int
  endMinutes     Int
}

// Окна на одну календарную дату (YYYY-MM-DD в логике org.timezone) — перекрывают шаблон WeeklySlot в этот день
model AdHocDaySlot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dateStr        String
  startMinutes   Int
  endMinutes     Int

  @@index([organizationId, dateStr])
}

// Полный выходной / отпуск: дата в формате YYYY-MM-DD в «логике» организации (календарный день)
model BlockedDate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dateStr        String
  reason         String?

  @@unique([organizationId, dateStr])
}

// Запись клиента на услугу
model Booking {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  clientName  String
  clientPhone String
  clientEmail String?
  notes       String?

  startsAt        DateTime
  endsAt          DateTime
  // Идемпотентный ключ для безопасных повторов одного и того же запроса на запись
  idempotencyKey String?
  // Статус оставлен строкой из-за ограничения SQLite по enum в текущей схеме
  status         String  @default("CONFIRMED")

  createdAt DateTime @default(now())

  // Связанные блокировки шагов сетки: их уникальность защищает от гонок и дублей
  slotLocks BookingSlotLock[]

  @@unique([organizationId, idempotencyKey])
}

// Блокировка занятости шага расписания (например, каждые 30 минут) для брони
model BookingSlotLock {
  id             String       @id @default(cuid())
  organizationId String
  bookingId      String
  slotStart      DateTime
  booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Уникальный шаг календаря в рамках организации — гарант от double-booking при конкуренции
  @@unique([organizationId, slotStart])
  @@index([bookingId])
}

// Одноразовый токен подтверждения email с дедлайном действия
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

// Одноразовый токен сброса пароля с дедлайном действия
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
